TARGET_NAME=EXAMPLE.SINGLE_ALL_NORMAL
DESCRIPTION="Example single-line SQL rule"
DOCUMENT_URL=https://example.com
DASHBOARD_URL=https://example.com
TAG_LIST=example,other
IS_ACTIVE=true
IS_MUTED=false
DATA_SOURCE=OPCMON_DB
SQL_TIMEOUT_SEC=30
SQL_JITTER_SEC=0
SQL_MODE=single
SCHEDULE_CRON="* * * * *"
MUTE_BETWEEN_ENABLED=true
MUTE_BETWEEN_RULES=[{"start":"04:00","end":"20:30","days":["SAT"]},{"start":"23:00","end":"06:00","days":["MON","TUE","WED","THU","FRI","SAT","SUN"]}]
MUTE_UNTIL_ENABLED=false
MUTE_UNTIL=
QUERY_FILE=EXAMPLE.SINGLE_ALL_NORMAL.sql

MAP_VAL1=NMETRIC
MAP_VAL2=MMETRIC
MAP_VAL3=CMETRIC
MAP_VAL4=DTTM
MAP_VAL5=SMSTR
MAP_VAL6=BASELINE

METRIC_COUNT=1
METRIC_1_NAME=CMETRIC
METRIC_1_VALUE=CMETRIC
METRIC_1_NORMAL_ACTION=NOOP
METRIC_1_NORMAL_MSG="{{METRIC_NAME}}  -- {{CMETRIC}}  normal -- ok"
METRIC_1_CRITICAL_1_OPERATOR=>
METRIC_1_CRITICAL_1_VAL=120
METRIC_1_CRITICAL_1_ACTION=CRITICAL_OPCMON
METRIC_1_CRITICAL_1_MSG="{{METRIC_NAME}}  -- {{CMETRIC}}  CRITICAL --  --    {{DTTM}}  -- {{SMSTR}}"
METRIC_1_MAJOR_1_OPERATOR=>
METRIC_1_MAJOR_1_VAL=110
METRIC_1_MAJOR_1_ACTION=MAJOR_MAIL
METRIC_1_MAJOR_1_MSG="{{METRIC_NAME}}  -- {{CMETRIC}}  MAJOR - CHECK EVA"
