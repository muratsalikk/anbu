TARGET_NAME=EXAMPLE.SINGLE
DESCRIPTION="Example single-line SQL rule"
DOCUMENT_URL=https://example.com
DASHBOARD_URL=https://example.com
TAG_LIST=example,other
IS_ACTIVE=true
IS_MUTED=true
DATA_SOURCE=OPCMON_DB
SQL_TIMEOUT_SEC=30
SQL_JITTER_SEC=0
SQL_MODE=single
SCHEDULE_CRON="* * * * *"
MUTE_BETWEEN_ENABLED=true
MUTE_BETWEEN_RULES=[{"start":"04:00","end":"20:30","days":["SAT"]},{"start":"23:00","end":"06:00","days":["MON","TUE","WED","THU","FRI","SAT","SUN"]}]
MUTE_UNTIL_ENABLED=true
MUTE_UNTIL="2026-05-27 10:31:00"
QUERY_FILE=EXAMPLE.SINGLE.sql

MAP_VAL1=NMETRIC
MAP_VAL2=MMETRIC
MAP_VAL3=CMETRIC
MAP_VAL4=DTTM
MAP_VAL5=SMSTR
MAP_VAL6=BASELINE

METRIC_COUNT=3
METRIC_1_NAME=NMETRIC
METRIC_1_VALUE=NMETRIC
METRIC_1_NORMAL_ACTION=NORMAL_OPCMON
METRIC_1_NORMAL_MSG="{{METRIC_NAME}}  -- {{NMETRIC}}  normal    --    {{DTTM}}  -- {{SMSTR}}"
METRIC_1_CRITICAL_1_OPERATOR=>
METRIC_1_CRITICAL_1_VAL=10
METRIC_1_CRITICAL_1_ACTION=CRITICAL_OPCMON
METRIC_1_CRITICAL_1_MSG="{{METRIC_NAME}}  -- {{NMETRIC}}  not normal -- check evaluator. -- {{NMETRIC}}  --- val: {{CONDITION_VALUE}}"
METRIC_2_NAME=MMETRIC
METRIC_2_VALUE=MMETRIC
METRIC_2_NORMAL_ACTION=NOOP
METRIC_2_NORMAL_MSG="{{METRIC_NAME}}  -- {{MMETRIC}}  normal -- check evaluator."
METRIC_2_CRITICAL_1_OPERATOR=<
METRIC_2_CRITICAL_1_VAL=4
METRIC_2_CRITICAL_1_ACTION=CRITICAL_OPCMON
METRIC_2_CRITICAL_1_MSG="{{METRIC_NAME}}  -- {{MMETRIC}}  critical-- check evaluator."
METRIC_2_MAJOR_1_OPERATOR="="
METRIC_2_MAJOR_1_VAL=10
METRIC_2_MAJOR_1_ACTION=MAJOR_MAIL
METRIC_2_MAJOR_1_MSG="{{METRIC_NAME}}  -- {{MMETRIC}} major. --    {{DTTM}}  -- {{SMSTR}}"
METRIC_3_NAME=CMETRIC
METRIC_3_VALUE=CMETRIC
METRIC_3_NORMAL_ACTION=NOOP
METRIC_3_NORMAL_MSG="{{METRIC_NAME}}  -- {{CMETRIC}}  normal -- check evaluator."
METRIC_3_CRITICAL_1_OPERATOR=>
METRIC_3_CRITICAL_1_VAL=50
METRIC_3_CRITICAL_1_ACTION=CRITICAL_OPCMON
METRIC_3_CRITICAL_1_MSG="{{METRIC_NAME}}  -- {{CMETRIC}}  CRITICAL --  --    {{DTTM}}  -- {{SMSTR}}"
METRIC_3_MAJOR_1_OPERATOR=>
METRIC_3_MAJOR_1_VAL=110
METRIC_3_MAJOR_1_ACTION=MAJOR_MAIL
METRIC_3_MAJOR_1_MSG="{{METRIC_NAME}}  -- {{CMETRIC}}  MAJOR - CHECK EVA"
